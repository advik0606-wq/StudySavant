{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "StudySet": {
      "title": "Study Set",
      "description": "A collection of notes, quizzes, and flashcards",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "quiz": { "type": "array" },
        "flashcards": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/studySets/{setId}": {
      "schema": "StudySet",
      "description": "User study sets containing notes and generated content"
    }
  }
}
